<UserControl x:Class="Tysl.Inspection.Desktop.App.Views.Pages.PreviewPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="24,24,24,12"
                Padding="20"
                Background="{DynamicResource HeroBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <StackPanel>
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="真实监控目录树、单点预览与异常复检" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#F3F4F6"
                           TextWrapping="Wrap"
                           Text="继续复用现有单点巡检链路，并在同一页内明确展示本地 SQLite 已落地的真实监控目录树、目录层级设备和最小对账结果，便于人工核对是否完整。" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#DDE7F2"
                           TextWrapping="Wrap"
                           Text="{Binding PageStatusText}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="真实监控目录树与所有点位设备" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding DirectoryStatusText}" />

                    <Grid Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Padding="12"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="目录总数" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding DirectoryGroupCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0"
                                Grid.Column="2"
                                Padding="12"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="设备总数" />
                                <TextBlock Margin="0,6,0,0"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Text="{Binding DirectoryDeviceCount}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="0"
                                Margin="0,12,0,0"
                                Padding="12"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="SQLite 快照" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="目录 " />
                                    <Run Text="{Binding DirectorySnapshotGroupCount}" />
                                    <Run Text=" / 设备 " />
                                    <Run Text="{Binding DirectorySnapshotDeviceCount}" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,12,0,0"
                                Padding="12"
                                Background="{DynamicResource WindowBackgroundBrush}"
                                BorderBrush="{DynamicResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="平台拉回" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding DirectoryPlatformSummaryText}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding DirectoryVerificationText}" />

                    <Border Margin="0,16,0,0"
                            Padding="12"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <ScrollViewer MaxHeight="340"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DirectoryGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Expander Margin="0,0,0,12"
                                                  Padding="8"
                                                  IsExpanded="True"
                                                  Background="{DynamicResource CardBrush}"
                                                  Foreground="{DynamicResource PrimaryTextBrush}">
                                            <Expander.Header>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DisplayText}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding HierarchyText}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding DeviceCountSummaryText}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="{Binding ChildrenHintText}" />
                                                </StackPanel>
                                            </Expander.Header>
                                            <StackPanel>
                                                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Text="{Binding EmptyStateText}" />
                                                <ItemsControl ItemsSource="{Binding Devices}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,8,0,0"
                                                                Padding="12"
                                                                Background="{DynamicResource WindowBackgroundBrush}"
                                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="12">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <StackPanel>
                                                                    <TextBlock FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                                               Text="{Binding DeviceName}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               Text="{Binding DeviceCode}" />
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               Text="{Binding OnlineStatusText}" />
                                                                </StackPanel>

                                                                <Button Grid.Column="1"
                                                                        Padding="14,8"
                                                                        Command="{Binding DataContext.SelectDirectoryDeviceCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="选中" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Expander>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <Border Margin="0,20,0,0"
                            Height="1"
                            Background="{DynamicResource CardBorderBrush}" />

                    <TextBlock Margin="0,20,0,0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="单点预览入口" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="继续先获取 RTSP 地址，再打开独立播放窗口；单点巡检与异常复检共用同一条现有链路。" />

                    <TextBlock Margin="0,20,0,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="选择点位" />
                    <ComboBox ItemsSource="{Binding Devices}"
                              SelectedItem="{Binding SelectedDevice}"
                              DisplayMemberPath="DisplayText"
                              MinHeight="38" />

                    <Button Margin="0,16,0,0"
                            Padding="16,10"
                            Command="{Binding RequestPreviewCommand}"
                            Content="获取预览地址" />

                    <Button Margin="0,12,0,0"
                            Padding="16,10"
                            Command="{Binding RequestInspectCommand}"
                            Content="巡检诊断" />

                    <Button Margin="0,12,0,0"
                            Padding="16,10"
                            Command="{Binding OpenPlayWinCommand}"
                            Content="打开播放窗口" />

                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding PlayWindowHintText}" />

                    <Border Margin="0,20,0,0"
                            Padding="16"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="点位详情" />

                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="平台设备信息" />

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="设备名称" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding DeviceName}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="设备编码" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding DeviceCode}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="所属目录路径" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviceDirectoryPathText}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="在线状态" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedDeviceOnlineStatusText}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="原始坐标来源" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedDeviceCoordinateSourceText}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="平台原始经纬度" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap">
                                        <Run Text="{Binding SelectedDeviceLatitudeText}" />
                                        <Run Text=" / " />
                                        <Run Text="{Binding SelectedDeviceLongitudeText}" />
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="地图渲染口径" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="{Binding SelectedDeviceMapCoordinateUsageText}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="地址 / 位置编码" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviceLocationText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="最近巡检结论" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviceRecentInspectText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="异常池摘要" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding SelectedDeviceAbnormalSummaryText}" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="处置状态" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedDeviceHandleStatusText}" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="恢复确认状态" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding SelectedDeviceRecoveredStatusText}" />
                                </StackPanel>
                            </Grid>

                            <Border Margin="0,16,0,0"
                                    Height="1"
                                    Background="{DynamicResource CardBorderBrush}" />

                            <TextBlock Margin="0,16,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="用户维护信息" />

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="维护状态" />
                            <TextBox Margin="0,4,0,0"
                                     Padding="10"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}"
                                     BorderThickness="1"
                                     Text="{Binding SelectedDeviceMaintenanceStatusText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="维护备注" />
                            <TextBox Margin="0,4,0,0"
                                     Padding="10"
                                     MinHeight="72"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding SelectedDeviceMaintenanceNoteText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="最近人工确认说明" />
                            <TextBox Margin="0,4,0,0"
                                     Padding="10"
                                     MinHeight="72"
                                     Background="{DynamicResource CardBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}"
                                     BorderThickness="1"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding SelectedDeviceManualConfirmationNoteText, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="最近保存时间" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding SelectedDeviceMaintenanceUpdatedAtText}" />

                            <Button Margin="0,16,0,0"
                                    Padding="16,10"
                                    Command="{Binding SaveSelectedDeviceMaintenanceCommand}"
                                    Content="保存维护信息" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,20,0,0"
                            Padding="16"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="最小巡检诊断结果" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="诊断结论" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding InspectConclusion}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="前置归类结果" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding InspectAbnormalClassText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="失败分类" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding InspectFailureCategory}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="阶段状态" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding InspectStageText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="最小诊断信息" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding InspectDetailText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="巡检时间" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="{Binding InspectAtText}" />

                            <TextBlock Margin="0,12,0,0"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="最小处置摘要" />
                            <TextBox Margin="0,4,0,0"
                                     Padding="12"
                                     MinHeight="96"
                                     Background="{DynamicResource WindowBackgroundBrush}"
                                     BorderBrush="{DynamicResource CardBorderBrush}"
                                     BorderThickness="1"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding InspectSummaryText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Padding="20"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="设备名称" />
                    <TextBlock Grid.Column="1"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding DeviceName}" />

                    <TextBlock Grid.Row="1"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="设备编码" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Margin="0,14,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding DeviceCode}" />

                    <TextBlock Grid.Row="2"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="当前诊断状态" />
                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding DiagnosisText}" />

                    <TextBlock Grid.Row="3"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="地址获取结果" />
                    <TextBlock Grid.Row="3"
                               Grid.Column="1"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding AddressStatusText}" />

                    <TextBlock Grid.Row="4"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="有效期 / 失效时间" />
                    <TextBlock Grid.Row="4"
                               Grid.Column="1"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding ExpireText}" />

                    <TextBlock Grid.Row="5"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="RTSP 地址" />
                    <TextBox Grid.Row="5"
                             Grid.Column="1"
                             Margin="0,14,0,0"
                             Padding="12"
                             MinHeight="120"
                             VerticalAlignment="Stretch"
                             Background="{DynamicResource WindowBackgroundBrush}"
                             BorderBrush="{DynamicResource CardBorderBrush}"
                             BorderThickness="1"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Text="{Binding RtspUrl}" />

                    <TextBlock Grid.Row="6"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="最近一次请求时间" />
                    <TextBlock Grid.Row="6"
                               Grid.Column="1"
                               Margin="0,14,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding RequestedAtText}" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Padding="20"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="当前异常池列表" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding AbnormalListHintText}" />

                    <ScrollViewer Margin="0,16,0,0"
                                  MaxHeight="360"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AbnormalItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12"
                                            Padding="16"
                                            Background="{DynamicResource WindowBackgroundBrush}"
                                            BorderBrush="{DynamicResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding DeviceDisplayText}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="{Binding InspectAtText}" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <Button Padding="14,8"
                                                        Command="{Binding DataContext.ReinspectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="复检" />
                                                <Button Margin="0,8,0,0"
                                                        Padding="14,8"
                                                        Command="{Binding DataContext.AdvanceHandleStatusCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding HandleActionText}" />
                                                <Button Margin="0,8,0,0"
                                                        Padding="14,8"
                                                        Command="{Binding DataContext.ToggleReviewedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="{Binding ReviewActionText}" />
                                            </StackPanel>

                                            <TextBlock Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,12,0,0"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextWrapping="Wrap">
                                                <Run Text="前置归类：" />
                                                <Run Text="{Binding AbnormalClassText}" />
                                                <Run Text="    结论：" />
                                                <Run Text="{Binding Conclusion}" />
                                                <Run Text="    已复核：" />
                                                <Run Text="{Binding ReviewedText}" />
                                                <Run Text="    处置状态：" />
                                                <Run Text="{Binding HandleStatusText}" />
                                                <Run Text="    已恢复确认：" />
                                                <Run Text="{Binding RecoveredConfirmedText}" />
                                            </TextBlock>

                                            <TextBlock Grid.Row="2"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,12,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="{Binding SummaryText}" />

                                            <TextBlock Grid.Row="3"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,12,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap">
                                                <Run Text="恢复确认时间：" />
                                                <Run Text="{Binding RecoveredConfirmedAtText}" />
                                                <Run Text="    恢复说明：" />
                                                <Run Text="{Binding RecoveredSummaryText}" />
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
