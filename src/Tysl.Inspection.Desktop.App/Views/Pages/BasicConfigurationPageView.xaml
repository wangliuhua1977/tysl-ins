<UserControl x:Class="Tysl.Inspection.Desktop.App.Views.Pages.BasicConfigurationPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock FontSize="26"
                       FontWeight="SemiBold"
                       Text="基础配置" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="本轮只提供“同步分组与设备”入口，不扩展编辑、设备详情、巡检、工单或通知。" />

            <Border Margin="0,24,0,0"
                    Padding="20"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="同步分组与设备" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding StatusText}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            MinWidth="168"
                            Margin="24,0,0,0"
                            Padding="20,10"
                            Command="{Binding SyncCommand}"
                            Content="同步分组与设备" />
                </Grid>
            </Border>

            <primitives:UniformGrid Margin="0,24,0,0"
                                    Columns="2"
                                    Rows="2">
                <Border Margin="0,0,16,16"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="分组数" />
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding GroupCount}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,0,16"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="设备数" />
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding DeviceCount}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,16,0"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="成功数" />
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding SuccessCount}" />
                    </StackPanel>
                </Border>
                <Border Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="失败数" />
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="SemiBold" Text="{Binding FailureCount}" />
                    </StackPanel>
                </Border>
            </primitives:UniformGrid>

            <Border Margin="0,24,0,0"
                    Padding="18"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="最近同步时间" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding LastSyncedAtText}" />
                </StackPanel>
            </Border>

            <Border Margin="0,24,0,0"
                    Padding="18"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="失败明细" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding FailureDetails}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
