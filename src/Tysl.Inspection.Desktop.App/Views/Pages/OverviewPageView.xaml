<UserControl x:Class="Tysl.Inspection.Desktop.App.Views.Pages.OverviewPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock FontSize="26"
                       FontWeight="SemiBold"
                       Text="运行总览" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Text="统计来自本地 SQLite，不直接实时查询平台。" />

            <primitives:UniformGrid Margin="0,24,0,0"
                                    Columns="2"
                                    Rows="2">
                <Border Margin="0,0,16,16"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="点位总数" />
                        <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="SemiBold" Text="{Binding TotalPoints}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,0,16"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="在线数" />
                        <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="SemiBold" Text="{Binding OnlineCount}" />
                    </StackPanel>
                </Border>
                <Border Margin="0,0,16,0"
                        Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="离线数" />
                        <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="SemiBold" Text="{Binding OfflineCount}" />
                    </StackPanel>
                </Border>
                <Border Padding="18"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="未定位数" />
                        <TextBlock Margin="0,10,0,0" FontSize="32" FontWeight="SemiBold" Text="{Binding UnlocatedCount}" />
                    </StackPanel>
                </Border>
            </primitives:UniformGrid>

            <Border Margin="0,24,0,0"
                    Padding="18"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="最近同步时间" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="{Binding LastSyncedAtText}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
