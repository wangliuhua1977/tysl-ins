<UserControl x:Class="Tysl.Inspection.Desktop.App.Views.Pages.MapPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Loaded="OnLoaded">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="24,24,24,12"
                Padding="20"
                Background="{DynamicResource HeroBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="点位态势地图" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#F3F4F6"
                               TextWrapping="Wrap"
                               Text="{Binding StatusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,10,0" Padding="12,8" Background="#1FFFFFFF" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="#DDE7F2" Text="已渲染" />
                            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding RenderedCount}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,10,0" Padding="12,8" Background="#1FFFFFFF" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="#DDE7F2" Text="在线" />
                            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding OnlineCount}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,10,0" Padding="12,8" Background="#1FFFFFFF" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="#DDE7F2" Text="离线" />
                            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding OfflineCount}" />
                        </StackPanel>
                    </Border>
                    <Border Padding="12,8" Background="#1FFFFFFF" CornerRadius="12">
                        <StackPanel>
                            <TextBlock Foreground="#DDE7F2" Text="未定位" />
                            <TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="{Binding UnlocatedCount}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="24,0,24,24"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="MapHost" />
        </Border>
    </Grid>
</UserControl>
