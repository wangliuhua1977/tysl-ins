<Window x:Class="Tysl.Inspection.Desktop.App.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:pages="clr-namespace:Tysl.Inspection.Desktop.App.Views.Pages"
        Title="天翼视联点位巡检系统"
        Width="1220"
        Height="820"
        MinWidth="1080"
        MinHeight="720"
        Loaded="OnLoaded"
        WindowStartupLocation="CenterScreen">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="24,24,24,0"
                Padding="24"
                Background="{DynamicResource HeroBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">
            <StackPanel>
                <TextBlock FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="天翼视联点位巡检系统" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#F3F4F6"
                           Text="{Binding PhaseText}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#D1D5DB"
                           TextWrapping="Wrap"
                           Text="{Binding ScopeText}" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="24"
                    Background="{DynamicResource CardBrush}">
            <TabItem Header="运行总览">
                <pages:OverviewPageView DataContext="{Binding Overview}" />
            </TabItem>
            <TabItem Header="基础配置">
                <pages:BasicConfigurationPageView DataContext="{Binding BasicConfiguration}" />
            </TabItem>
            <TabItem Header="点位态势地图">
                <pages:MapPageView DataContext="{Binding Map}" />
            </TabItem>
            <TabItem Header="主题设置">
                <pages:ThemeSettingsPageView DataContext="{Binding ThemeSettings}" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
