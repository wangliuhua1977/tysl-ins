<Window x:Class="Tysl.Inspection.Desktop.App.Views.PlayWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="{Binding WindowTitle}"
        Width="960"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        Loaded="OnLoaded"
        Closed="OnClosed"
        WindowStartupLocation="CenterOwner">
    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="20,20,20,12"
                Padding="18"
                Background="{DynamicResource HeroBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="{Binding StatusText}" />
                <TextBlock Margin="0,8,0,0"
                           Foreground="#E7EEF6"
                           TextWrapping="Wrap"
                           Text="{Binding StatusHintText}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="20,0,20,12"
                Padding="12"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid Background="#111827">
                <vlc:VideoView MediaPlayer="{Binding MediaPlayer}" />
                <TextBlock Margin="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#D1D5DB"
                           FontSize="16"
                           Text="若当前未出画，请查看顶部状态与底部失败提示。"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="20,0,20,20"
                Padding="18"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="设备名称" />
                    <TextBlock Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding DeviceName}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="设备编码" />
                    <TextBlock Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding DeviceCode}" />

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="掩码 RTSP 地址" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding MaskedRtspUrl}" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom">
                    <Button MinWidth="132"
                            Padding="16,10"
                            Command="{Binding StopPlayCommand}"
                            Content="停止播放" />
                    <Button Margin="0,10,0,0"
                            MinWidth="132"
                            Padding="16,10"
                            Command="{Binding CloseWinCommand}"
                            Content="关闭窗口" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
