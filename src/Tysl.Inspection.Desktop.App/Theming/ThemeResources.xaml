<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F7FB" />
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#D9E0EA" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5B6472" />
    <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="#0F4C81" />
        <GradientStop Offset="0.5" Color="#1368AA" />
        <GradientStop Offset="1" Color="#1B8BC8" />
    </LinearGradientBrush>

    <Style TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="#0F4C81" />
        <Setter Property="BorderBrush" Value="#0F4C81" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
